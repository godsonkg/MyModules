#!name=节点 IP 质量检测（Surge）
#!desc=自动识别 Surge 主策略组及当前选中的节点，检测其出口 IP 类型、原始风险、风险标记，以及流媒体与 AI 可用性。无需配置参数。
#!author=MaYIHEI（原始检测逻辑） / Codex（Surge 适配）
#!homepage=https://github.com/MaYIHEI/paperclip/tree/main/loon/ipquality
#!system=ios
# 使用：先在 Surge 主策略组中选好节点，再到「脚本」页面长按
# “节点 IP 质量检测”并运行。脚本会自动读取策略组当前选择，无需模块参数。

[Script]
节点 IP 质量检测 = type=generic,timeout=60,engine=webview,script-path=https://raw.githubusercontent.com/godsonkg/MyModules/main/Scripts/ipquality_surge.js,script-update-interval=3600
